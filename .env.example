# ── App ─────────────────────────────────────────────────────────────
APP_NAME=rd-knowledge-map-backend
DEBUG=false

# ── Backend ─────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=rd_knowledge_map
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:change_me@postgres:5432/rd_knowledge_map

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── Elasticsearch ───────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_TRANSPORT_PORT=9300

# ── Neo4j ───────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ── MinIO ───────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=rd-documents
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── LLM Provider ────────────────────────────────────────────────────
LLM_PROVIDER=mock

# ── YandexGPT (placeholders only — never commit real keys) ──────────
YANDEX_API_KEY=change_me
YANDEX_FOLDER_ID=change_me
YANDEX_LLM_MODEL=yandexgpt-lite
YANDEX_LLM_MODEL_VERSION=latest
YANDEX_LLM_ENDPOINT=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
YANDEX_EMBEDDINGS_ENABLED=false
YANDEX_EMBEDDING_QUERY_MODEL=text-search-query
YANDEX_EMBEDDING_DOC_MODEL=text-search-doc
YANDEX_EMBEDDING_ENDPOINT=https://llm.api.cloud.yandex.net/foundationModels/v1/textEmbedding

# ── LLM common ──────────────────────────────────────────────────────
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=3000
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# ── Local LLM fallback ──────────────────────────────────────────────
LOCAL_LLM_ENDPOINT=http://ollama:11434
LOCAL_LLM_MODEL=qwen2.5:7b-instruct
